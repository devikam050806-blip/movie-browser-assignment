{
  "name": "starter-cra-and-react",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "concurrently": "^5.0.2",
    "express": "^4.17.1",
    "http-proxy-middleware": "^1.0.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-router-dom": "^6.30.4",
    "react-scripts": "^3.4.0"
  },
  "scripts": {
    "start": "npm run development",
    "development": "concurrently --kill-others \"npm run client\" \"npm run server\"",
    "production": "npm run build && npm run server",
    "server": "node server/index.js",
    "client": "node scripts/react-scripts.js start",
    "build": "node scripts/react-scripts.js build",
    "test": "node scripts/react-scripts.js test",
    "eject": "node scripts/react-scripts.js eject"
  },
  "engines": {
    "node": "10.x"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "license": "MIT"
}
